# 环境配置（复制此文件为 .env 并填写真实值）

NODE_ENV=development
PORT=3000
ENABLE_DEV_ROUTES=false
SERVER_BASE_URL=http://localhost:3000
WS_CORS_ORIGIN=http://localhost:5173

# MongoDB 连接
MONGODB_URI=mongodb://localhost:27017/shehong-jianshe

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# 微信小程序
WX_APP_ID=your-appid-here
WX_APP_SECRET=your-appsecret-here

# 飞书机器人 webhook（用于消息推送）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# 飞书开放平台应用（用于群消息 @人）
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret
FEISHU_CHAT_ID=your-chat-id

# 飞书多维表格
FEISHU_BITABLE_APP_TOKEN=your-bitable-app-token
FEISHU_BITABLE_TABLE_ID=your-table-id

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 日志
LOG_LEVEL=info
LOG_DIR=./logs
