.timeline {
  padding: 8rpx 0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  min-height: 80rpx;
}

.timeline-axis {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #E8E8E8;
  border: 4rpx solid #BFBFBF;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.dot-active {
  background: #1E6F3F;
  border-color: #1E6F3F;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  min-height: 40rpx;
  background: #E8E8E8;
  margin-top: 4rpx;
}

.timeline-content {
  flex: 1;
  padding-bottom: 32rpx;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.timeline-time {
  font-size: 22rpx;
  color: #8C8C8C;
}

.timeline-operator {
  font-size: 22rpx;
  color: #1890FF;
}

.timeline-text {
  font-size: 26rpx;
  color: #595959;
  line-height: 1.6;
}
