<view class="timeline">
  <view class="timeline-item" wx:for="{{events}}" wx:key="index">
    <!-- 左侧轴线 -->
    <view class="timeline-axis">
      <view class="timeline-dot dot-active" style="background:{{item.color||'#1E6F3F'}};border-color:{{item.color||'#1E6F3F'}};"></view>
      <view class="timeline-line" wx:if="{{index < events.length - 1}}"></view>
    </view>
    <!-- 右侧内容 -->
    <view class="timeline-content">
      <view class="timeline-header">
        <text class="timeline-time">{{item.time}}</text>
        <text class="timeline-operator timeline-name" wx:if="{{item.operator}}">{{item.operator}}</text>
      </view>
      <view class="timeline-text" wx:if="{{item.contentParts && item.contentParts.length}}">
        <text
          wx:for="{{item.contentParts}}"
          wx:for-item="part"
          wx:for-index="partIndex"
          wx:key="partIndex"
          class="{{part.highlight ? 'timeline-content-name' : ''}}"
        >{{part.text}}</text>
      </view>
      <text class="timeline-text" wx:else>{{item.content}}</text>
    </view>
  </view>
</view>
