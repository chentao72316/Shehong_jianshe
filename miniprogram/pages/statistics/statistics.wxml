<view class="page-container">
  <!-- 时间范围选择 -->
  <view class="filter-bar card">
    <text class="filter-label">时间范围</text>
    <picker range="{{timeRangeOptions}}" range-key="label" bindchange="onTimeRangeChange">
      <view class="filter-value">
        {{timeRangeOptions[timeRangeIndex].label}} ▾
      </view>
    </picker>
  </view>

  <!-- 网格维度统计 -->
  <view class="card" wx:if="{{gridStats.length > 0}}">
    <text class="section-title">网格维度统计</text>
    <view class="stats-table">
      <view class="table-header">
        <text class="th">网格</text>
        <text class="th">总量</text>
        <text class="th">完成</text>
        <text class="th">存量</text>
        <text class="th">施工</text>
        <text class="th">超时</text>
        <text class="th">完成率</text>
      </view>
      <view class="table-row" wx:for="{{gridStats}}" wx:key="gridName">
        <text class="td">{{item.gridName}}</text>
        <text class="td">{{item.total}}</text>
        <text class="td text-success">{{item.done}}</text>
        <text class="td text-success">{{item.existingResourceDone || item.existingResourceCompleted || 0}}</text>
        <text class="td text-info">{{item.constructionBuildDone || item.constructionBuildCompleted || 0}}</text>
        <text class="td text-danger">{{item.timeout}}</text>
        <text class="td">{{item.doneRate}}%</text>
      </view>
    </view>
  </view>

  <!-- 区域维度统计 -->
  <view class="card" wx:if="{{areaStats.length > 0}}">
    <text class="section-title">区域维度统计</text>
    <view class="stats-table">
      <view class="table-header">
        <text class="th">区域</text>
        <text class="th">总量</text>
        <text class="th">完成</text>
        <text class="th">存量</text>
        <text class="th">施工</text>
        <text class="th">超时</text>
        <text class="th">完成率</text>
      </view>
      <view class="table-row" wx:for="{{areaStats}}" wx:key="area">
        <text class="td">{{item.area}}</text>
        <text class="td">{{item.total}}</text>
        <text class="td text-success">{{item.done}}</text>
        <text class="td text-success">{{item.existingResourceDone || item.existingResourceCompleted || 0}}</text>
        <text class="td text-info">{{item.constructionBuildDone || item.constructionBuildCompleted || 0}}</text>
        <text class="td text-danger">{{item.timeout}}</text>
        <text class="td">{{item.doneRate}}%</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && gridStats.length === 0 && areaStats.length === 0}}">
    <text class="empty-text">暂无统计数据</text>
  </view>
</view>
