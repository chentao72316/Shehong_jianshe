.radio-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 32rpx;
  font-size: 28rpx;
  color: #262626;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #595959;
  margin-bottom: 10rpx;
}

.form-label.required::before {
  content: '* ';
  color: #F5222D;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #262626;
  background: #FAFAFA;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #262626;
  background: #FAFAFA;
  box-sizing: border-box;
}

.file-upload {
  height: 80rpx;
  border: 2rpx dashed #1E6F3F;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  overflow: hidden;
  border-radius: 8rpx;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E8E8E8;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #F5222D;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.file-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E8E8E8;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.file-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E6F3F;
}

.file-icon-label {
  font-size: 20rpx;
  color: #8C8C8C;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #BFBFBF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #BFBFBF;
}

.file-upload {
  min-height: 200rpx;
  border: 2rpx dashed #1E6F3F;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.file-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.file-thumb {
  width: 300rpx;
  height: 300rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E8E8E8;
}

.error-tip {
  display: block;
  font-size: 22rpx;
  color: #F5222D;
  margin-top: 6rpx;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.08);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
}

.placeholder {
  color: #BFBFBF;
}
