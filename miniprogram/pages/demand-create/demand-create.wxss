.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #595959;
  margin-bottom: 10rpx;
}

.form-label.required::before {
  content: '* ';
  color: #F5222D;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #262626;
  background: #FAFAFA;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #262626;
  background: #FAFAFA;
  box-sizing: border-box;
}

.picker-value {
  height: 80rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #262626;
  background: #FAFAFA;
  display: flex;
  align-items: center;
}

.picker-value.placeholder {
  color: #BFBFBF;
}

.placeholder {
  color: #BFBFBF;
}

.location-selector {
  height: 80rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #FAFAFA;
  display: flex;
  align-items: center;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E8E8E8;
}

.photo-item {
  position: relative;
}

.file-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E8E8E8;
  background: #FAFAFA;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  box-sizing: border-box;
}

.file-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.file-name {
  font-size: 20rpx;
  color: #8C8C8C;
  text-align: center;
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #BFBFBF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #BFBFBF;
  cursor: pointer;
}

.error-tip {
  display: block;
  font-size: 22rpx;
  color: #F5222D;
  margin-top: 6rpx;
}

.cross-area-tip {
  display: block;
  font-size: 22rpx;
  color: #FA8C16;
  margin-top: 6rpx;
  line-height: 1.5;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.08);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
}
