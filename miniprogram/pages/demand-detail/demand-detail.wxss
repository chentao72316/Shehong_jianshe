.detail-header {
  position: relative;
  overflow: hidden;
  padding-bottom: 28rpx;
  padding-right: 120rpx;
}

.demand-no {
  font-size: 30rpx;
  font-weight: bold;
  color: #262626;
}

.status-ribbon {
  position: absolute;
  top: 18rpx;
  right: -52rpx;
  width: 180rpx;
  height: 44rpx;
  background: #1677FF;
  transform: rotate(45deg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(22, 119, 255, 0.22);
}

.status-ribbon-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.progress-bar-wrap {
  width: 100%;
  height: 12rpx;
  background: #F5F5F5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: #1E6F3F;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.info-row-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.info-row-item:last-child {
  width: 100%;
}

.info-key {
  font-size: 22rpx;
  color: #8C8C8C;
}

.info-val {
  font-size: 28rpx;
  color: #262626;
}

.info-val-remark {
  word-break: break-all;
  white-space: pre-wrap;
}

.photo-section {
  width: 100%;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.photo-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.file-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E8E8E8;
  background: #FAFAFA;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  box-sizing: border-box;
}

.file-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.file-name {
  font-size: 22rpx;
  color: #8C8C8C;
  text-align: center;
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.action-card {
  display: flex;
  flex-direction: column;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 600rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #262626;
  display: block;
  margin-bottom: 24rpx;
}

.remark-input {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #8C8C8C;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8C8C8C;
}

.picker-value {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #262626;
}

.picker-value.placeholder {
  color: #BFBFBF;
}

/* 步骤条样式 */
.steps-wrap {
  padding: 20rpx 0;
}

.steps {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #D9D9D9;
  border: 4rpx solid #D9D9D9;
  position: relative;
  z-index: 2;
}

.step-item.done .step-dot {
  background: #1E6F3F;
  border-color: #1E6F3F;
}

.step-item.current .step-dot {
  background: #1890FF;
  border-color: #1890FF;
  box-shadow: 0 0 0 6rpx rgba(24, 144, 255, 0.2);
}

.step-line {
  position: absolute;
  top: 10rpx;
  left: calc(50% + 12rpx);
  right: calc(-50% + 12rpx);
  height: 4rpx;
  background: #D9D9D9;
  z-index: 1;
}

.step-item.done .step-line {
  background: #1E6F3F;
}

.step-label {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 12rpx;
  text-align: center;
  white-space: nowrap;
}

.step-item.done .step-label,
.step-item.current .step-label {
  color: #262626;
}

/* 监理验收弹窗样式 */
.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  font-size: 28rpx;
}
