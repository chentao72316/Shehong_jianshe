.msg-list { }

.msg-item { display: flex; align-items: flex-start; padding: 24rpx 32rpx; background: #fff; border-bottom: 1rpx solid #F5F5F5; position: relative; }

.msg-item.unread { background: #FFFBE6; }

.msg-item.system-msg { background: #EEF5FF; }

.msg-item.system-msg.unread { background: #DDE9FF; }

.msg-dot { width: 16rpx; height: 16rpx; background: #F5222D; border-radius: 50%; flex-shrink: 0; margin-top: 12rpx; margin-right: 16rpx; }

.msg-content { flex: 1; }

.msg-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }

.msg-title-row { display: flex; align-items: center; gap: 8rpx; flex: 1; overflow: hidden; }

.msg-type-tag { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 8rpx; flex-shrink: 0; }

.system-tag { background: #1677FF; color: #fff; }

.msg-title { font-size: 28rpx; font-weight: bold; color: #262626; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.msg-time { font-size: 22rpx; color: #BFBFBF; flex-shrink: 0; margin-left: 16rpx; }

.msg-body { font-size: 26rpx; color: #595959; line-height: 1.6; }

.empty-state { display: flex; align-items: center; justify-content: center; padding: 120rpx 0; }

.empty-text { font-size: 28rpx; color: #BFBFBF; }

.load-more { text-align: center; padding: 24rpx; font-size: 24rpx; color: #BFBFBF; }
