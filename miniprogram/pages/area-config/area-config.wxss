.toolbar { display: flex; justify-content: flex-end; }
.add-btn { font-size: 28rpx; }

.area-item { padding: 24rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.area-item:last-child { border-bottom: none; }

.area-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.area-name { font-size: 32rpx; font-weight: 600; color: #262626; }

.area-actions { display: flex; gap: 24rpx; }
.action-link { font-size: 26rpx; color: #1890FF; }
.text-danger { color: #F5222D; }

.area-info-row { display: flex; margin-bottom: 6rpx; }
.info-label { font-size: 24rpx; color: #8C8C8C; flex-shrink: 0; }
.info-val { font-size: 24rpx; color: #595959; }

.empty-state { padding: 60rpx; text-align: center; }
.empty-text { font-size: 28rpx; color: #BFBFBF; }
.loading-state { padding: 60rpx; text-align: center; }

.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal-box { background: #fff; border-radius: 24rpx; padding: 40rpx; width: 640rpx; }
.modal-title { display: block; font-size: 32rpx; font-weight: 600; color: #262626; margin-bottom: 24rpx; text-align: center; }
.modal-scroll { max-height: 70vh; }

.form-item { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 26rpx; color: #595959; margin-bottom: 8rpx; }
.required::before { content: '*'; color: #F5222D; margin-right: 4rpx; }
.form-input { width: 100%; height: 72rpx; border: 1rpx solid #E8E8E8; border-radius: 8rpx; padding: 0 16rpx; font-size: 28rpx; box-sizing: border-box; }
.form-input-readonly { background: #F5F5F5; color: #8C8C8C; }

.candidate-list { display: flex; flex-wrap: wrap; gap: 12rpx; min-height: 56rpx; padding: 8rpx 0; }
.candidate-tag { display: flex; align-items: center; gap: 8rpx; background: #E6F7FF; border: 1rpx solid #91D5FF; border-radius: 8rpx; padding: 8rpx 16rpx; font-size: 26rpx; color: #096DD9; }
.remove-tag { color: #8C8C8C; font-size: 28rpx; line-height: 1; }
.candidate-add { font-size: 26rpx; color: #1890FF; padding: 8rpx 0; cursor: pointer; }

.modal-btns { display: flex; gap: 24rpx; margin-top: 32rpx; }
.modal-btn { flex: 1; font-size: 30rpx; }

.pick-list { max-height: 50vh; overflow-y: auto; }
.pick-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #F5F5F5; position: relative; }
.pick-item-selected { background: #F0F9E8; }
.pick-name { font-size: 30rpx; color: #262626; flex: 1; }
.pick-phone { font-size: 24rpx; color: #8C8C8C; margin-right: 16rpx; }
.pick-check { font-size: 32rpx; color: #1E6F3F; }

/* 选项选择弹窗 */
.picker-row { display: flex; align-items: center; justify-content: space-between; min-height: 72rpx; border: 1rpx solid #E8E8E8; border-radius: 8rpx; padding: 0 16rpx; background: #fff; }
.picker-row-disabled { background: #F5F5F5; }
.picker-val { font-size: 28rpx; color: #262626; }
.picker-placeholder { font-size: 28rpx; color: #BFBFBF; }
.picker-arrow { font-size: 36rpx; color: #BFBFBF; }
.option-item { padding: 24rpx 0; border-bottom: 1rpx solid #F5F5F5; font-size: 30rpx; color: #262626; }
.option-item:last-child { border-bottom: none; }
.option-item-add { color: #1890FF; font-size: 28rpx; }
.manual-input-row { display: flex; gap: 16rpx; align-items: center; margin-top: 16rpx; }
.manual-input { flex: 1; }
.manual-confirm-btn { flex-shrink: 0; font-size: 28rpx; padding: 0 24rpx; height: 72rpx; line-height: 72rpx; }
