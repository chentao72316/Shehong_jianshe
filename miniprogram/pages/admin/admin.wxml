<view class="page-container">
  <view class="card">
    <text class="section-title">需求汇总</text>
    <view class="stats-row">
      <view class="stat-item"><text class="stat-num">{{stats.total}}</text><text class="stat-label">总量</text></view>
      <view class="stat-item"><text class="stat-num text-info">{{stats.designing}}</text><text class="stat-label">设计中</text></view>
      <view class="stat-item"><text class="stat-num text-info">{{stats.constructing}}</text><text class="stat-label">施工中</text></view>
      <view class="stat-item"><text class="stat-num text-success">{{stats.done}}</text><text class="stat-label">已开通</text></view>
      <view class="stat-item"><text class="stat-num text-danger">{{stats.timeout}}</text><text class="stat-label">超时</text></view>
    </view>
  </view>

  <view class="card">
    <text class="section-title">管理功能</text>
    <view class="menu-list">
      <view class="menu-item" data-url="/pages/demand-list/demand-list" bindtap="onNavTo">
        <text class="menu-label">全部需求</text>
        <text class="menu-badge" wx:if="{{stats.total}}">{{stats.total}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" data-url="/pages/timeout-list/timeout-list" bindtap="onNavTo">
        <text class="menu-label">超时督办</text>
        <text class="menu-badge danger" wx:if="{{timeoutCount}}">{{timeoutCount}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" data-url="/pages/staff-config/staff-config" bindtap="onNavTo">
        <text class="menu-label">人员配置</text>
        <text class="menu-badge" wx:if="{{staffCount}}">{{staffCount}}人</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" data-url="/pages/area-config/area-config" bindtap="onNavTo">
        <text class="menu-label">区域配置</text>
        <text class="menu-badge" wx:if="{{areaConfigCount}}">{{areaConfigCount}}条</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" data-url="/pages/system-config/system-config" bindtap="onNavTo">
        <text class="menu-label">系统配置</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" data-url="/pages/role-config/role-config" bindtap="onNavTo">
        <text class="menu-label">角色权限</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" data-url="/pages/statistics/statistics" bindtap="onNavTo">
        <text class="menu-label">统计分析</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
