.stats-row { display: flex; justify-content: space-around; padding: 16rpx 0; }

.stat-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }

.stat-num { font-size: 44rpx; font-weight: bold; color: #262626; }

.stat-label { font-size: 22rpx; color: #8C8C8C; }

.menu-list { }

.menu-item { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #F5F5F5; }

.menu-item:last-child { border-bottom: none; }

.menu-label { flex: 1; font-size: 30rpx; color: #262626; }

.menu-badge { background: #F5F5F5; color: #595959; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 20rpx; margin-right: 12rpx; }

.menu-badge.danger { background: #FFF1F0; color: #F5222D; }

.arrow { font-size: 40rpx; color: #BFBFBF; }
