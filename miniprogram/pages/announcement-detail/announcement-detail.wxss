.page-container {
  padding: 32rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.loading-tip, .empty-tip {
  text-align: center;
  color: #8C8C8C;
  font-size: 28rpx;
  padding-top: 100rpx;
}

.announcement-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.ann-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #262626;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.ann-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.ann-time {
  font-size: 24rpx;
  color: #8C8C8C;
}

.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin-bottom: 24rpx;
}

.ann-content {
  font-size: 30rpx;
  color: #595959;
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
}
