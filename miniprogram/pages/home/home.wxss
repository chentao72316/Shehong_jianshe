.header-banner {
  background: linear-gradient(135deg, #1E6F3F, #2A8F55);
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.role-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.header-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.stats-card {
  margin-top: -24rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #262626;
}

.stat-label {
  font-size: 22rpx;
  color: #8C8C8C;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.shortcut-icon {
  font-size: 48rpx;
}

.shortcut-label {
  font-size: 22rpx;
  color: #595959;
  text-align: center;
}

/* 走马灯公告栏 */
.marquee-bar {
  display: flex;
  align-items: center;
  background: #e8f5ee;
  padding: 0 24rpx;
  height: 72rpx;
  margin: 0 0 20rpx;
  border-left: 6rpx solid #1E6F3F;
}

.marquee-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.marquee-swiper {
  flex: 1;
  height: 72rpx;
}

.marquee-text {
  font-size: 26rpx;
  color: #1E6F3F;
  line-height: 72rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.marquee-arrow {
  font-size: 32rpx;
  color: #1E6F3F;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 区域标题行 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #1E6F3F;
}

/* 待办列表 */
.pending-card {
  margin-top: 20rpx;
}

/* 空状态 */
.empty-card {
  text-align: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8c8c8c;
}

/* 颜色辅助类 */
.text-info {
  color: #1890ff;
}

.text-danger {
  color: #f5222d;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-critical {
  color: #ff4d4f;
}
